{
  "name": "aftercall",
  "version": "0.5.0",
  "private": false,
  "description": "Auto-ingest Bluedot meeting transcripts into Cloudflare D1 + Vectorize, route action items into a Notion Followups inbox, and query the indexed calls from Claude.ai via MCP.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "node scripts/deploy.mjs",
    "notes:intake": "node scripts/obsidian-intake.ts",
    "ci:wrangler-config": "node scripts/write-ci-wrangler-toml.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "setup": "node scripts/setup.ts"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sentry/cloudflare": "^10.50.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.0",
    "openai": "^6.34.0",
    "svix": "^1.92.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.40",
    "@cloudflare/workers-types": "^4.20241224.0",
    "@sentry/cli": "^3.4.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "4.1.5",
    "wrangler": "^4.82.2"
  }
}
